{
  "name": "veltophp/velto",
  "description": "Velto - The lightweight PHP framework with RVC architecture — perfect for modern static web projects",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "veltophp",
      "email": "dev@veltophp.com"
    }
  ],
  "require": {
    "php": ">=8.0",
    "veltophp/velto-core": "^1.0.5",
    "veltophp/axion": "dev-main",
    "league/commonmark": "^2.7"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Velto\\Axion\\Controllers\\": "axion/controllers/",
      "Velto\\Axion\\Models\\": "axion/models/",
      "Velto\\Axion\\Middleware\\": "axion/middleware/",
      "Velto\\Axion\\App\\": "axion/app/",
      "Velto\\Axion\\": "vendor/veltophp/axion/src/",
      "Veltophp\\VeltoCli\\": "vendor/veltophp/velto-cli/src/"
    }
  },
  "scripts": {
    "start": "php velto start"
  },
  "repositories": [
    {
      "type": "path",
      "url": "vendor/veltophp/axion"
    },
    {
      "type": "path",
      "url": "vendor/veltophp/velto-cli"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true
}
